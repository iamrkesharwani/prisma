generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  age   Int
}

model Notes {
  id        Int      @id @default(autoincrement())
  title     String   @unique
  content   String
  createdAt DateTime @default(now())
}
